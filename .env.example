# ==========================================
# Aliança Transportes LTDA - ambiente local
# ==========================================

# Discord — opcional/fallback
# Token secreto do seu bot. NÃO envie esse token para ninguém.
DISCORD_BOT_TOKEN=COLE_AQUI_O_TOKEN_DO_SEU_BOT
DISCORD_VTLOG_CHANNEL_ID=1509152627500384327
DISCORD_ALERT_CHANNEL_ID=1509152695427006484
DISCORD_REPORT_CHANNEL_ID=1509152810879553588
DISCORD_ERROR_CHANNEL_ID=1509152844232658994
SITE_URL=http://localhost:3000
DISCORD_IMPORT_SECRET=alianca-discord-local-2026

# VTLog API — integração principal
# Modo pessoal: usa apenas seu Steam ID e não precisa do token da empresa.
# Modo VTC/empresa: usa VTLOG_API_TOKEN + VTLOG_VTC_ID.
VTLOG_MODE=personal
VTLOG_STEAM_ID=76561198943363609

# Base oficial da API do VTLog
VTLOG_API_URL=https://api.vtlog.net

# Cole o token Bearer da sua VTC aqui, somente no seu computador.
VTLOG_API_TOKEN=COLE_AQUI_O_TOKEN_DA_API_VTLOG

# ID numérico da VTC/empresa dentro do VTLog.
VTLOG_VTC_ID=COLE_AQUI_O_ID_NUMERICO_DA_VTC

# Filtros opcionais
VTLOG_API_VERSION=v2
VTLOG_GAME=ETS2
VTLOG_BOARD=
VTLOG_JOBS_LIMIT=25

# VTLog Job Webhook — usado quando o VTLog envia a entrega direto para o site.
# Deixe vazio para teste local. Em produção, troque por um segredo forte.
VTLOG_WEBHOOK_SECRET=
